### 3.4 `graph/attachment_client.py`

```python
"""
attachment_client.py
======================
Contains Graph API functions for listing and downloading email
attachments. This file's job is strictly "get the file" — it does NOT
read or parse the file's content. That responsibility belongs to
parsers/parser_router.py.

Why this file exists:
    Keeping "download the attachment" separate from "understand the
    attachment's content" means parsers/ can be tested completely
    independently (e.g. with a sample PDF from disk) without needing a
    live mailbox connection at all.

Design notes:
    - Graph API attachments come back as base64-encoded content embedded
      in JSON for small files. The SDK handles this decoding for us, but
      we still need to check the attachment type to know we're dealing
      with a fileAttachment (as opposed to an itemAttachment, e.g. a
      forwarded email, which Phase 1 does not support).
    - A size guard (MAX_ATTACHMENT_SIZE_MB) prevents accidentally trying
      to download and process an enormous file that could slow down or
      crash the parsing step.
"""

# ---------------------------------------------------------------------------
# Imports
# ---------------------------------------------------------------------------
import base64

from graph.graph_client_factory import build_graph_client
from config.settings import settings
from utils.logger import get_logger

logger = get_logger(__name__)


# ---------------------------------------------------------------------------
# Function: list_message_attachments
# ---------------------------------------------------------------------------
async def list_message_attachments(message_id: str) -> list[dict]:
    """
    List all attachments on a specific email message, without
    downloading their actual content (metadata only — fast operation).

    Args:
        message_id (str): The unique Graph API ID of the parent email.

    Returns:
        list[dict]: A list of attachment metadata dictionaries (id, name,
                    contentType, size).
    """
    logger.debug(f"Calling Graph API: GET /me/messages/{message_id}/attachments")

    client = build_graph_client()

    response = await client.me.messages.by_message_id(message_id).attachments.get()

    attachments = response.value if response and response.value else []

    result = []
    for att in attachments:
        result.append({
            "id": att.id,
            "name": att.name,
            "contentType": att.content_type,
            "size": att.size,
        })

    return result


# ---------------------------------------------------------------------------
# Function: download_attachment
# ---------------------------------------------------------------------------
async def download_attachment(message_id: str, attachment_id: str) -> tuple[bytes, str, str]:
    """
    Download the raw binary content of a specific email attachment.

    Args:
        message_id (str): The unique Graph API ID of the parent email.
        attachment_id (str): The unique ID of the attachment to download.

    Returns:
        tuple[bytes, str, str]: (file_bytes, file_name, content_type)
            - file_bytes: The raw decoded binary content of the file.
            - file_name: The original file name (e.g. "CV.pdf").
            - content_type: The MIME type reported by Graph API.

    Raises:
        ValueError: If the attachment exceeds MAX_ATTACHMENT_SIZE_MB,
                    or if it's not a simple file attachment (e.g. it's
                    an embedded email, which Phase 1 doesn't support).
    """
    logger.debug(
        f"Calling Graph API: GET /me/messages/{message_id}/attachments/{attachment_id}"
    )

    client = build_graph_client()

    # Step 1: Fetch the attachment object. For small-to-medium files,
    #         Graph API includes the base64-encoded content directly in
    #         this response (this is the "fileAttachment" type).
    attachment = await (
        client.me.messages.by_message_id(message_id)
        .attachments.by_attachment_id(attachment_id)
        .get()
    )

    # Step 2: Enforce our configured size limit BEFORE attempting to
    #         decode/process the content, to fail fast on oversized files.
    size_mb = (attachment.size or 0) / (1024 * 1024)
    if size_mb > settings.MAX_ATTACHMENT_SIZE_MB:
        raise ValueError(
            f"Attachment '{attachment.name}' is {size_mb:.1f}MB, which "
            f"exceeds the configured limit of "
            f"{settings.MAX_ATTACHMENT_SIZE_MB}MB."
        )

    # Step 3: Confirm this is a fileAttachment (has content_bytes) rather
    #         than an itemAttachment (e.g. a forwarded email/contact),
    #         which Phase 1 does not handle.
    content_bytes_b64 = getattr(attachment, "content_bytes", None)

    if content_bytes_b64 is None:
        raise ValueError(
            f"Attachment '{attachment.name}' is not a standard file "
            f"attachment (it may be an embedded email or contact card), "
            f"which isn't supported yet."
        )

    # Step 4: The SDK may already hand us decoded bytes, or a base64
    #         string, depending on the SDK version's typing. We check
    #         and decode defensively to handle either case correctly.
    if isinstance(content_bytes_b64, bytes):
        file_bytes = content_bytes_b64
    else:
        file_bytes = base64.b64decode(content_bytes_b64)

    return file_bytes, attachment.name, attachment.content_type
