### 3.2 `graph/mail_client.py`

```python
"""
mail_client.py
==============
Contains every Graph API function related to reading and searching
Outlook email. This file knows about Graph's mail endpoints and nothing
else — it has no knowledge of MCP tools, the LLM, or attachment parsing.

Why this file exists:
    tools/email_tools.py and tools/attachment_tools.py both need to fetch
    email data. Rather than each tool file calling the Graph SDK directly
    (which would duplicate connection logic and make future Graph API
    changes painful to track down), they all call through this one file.

Design notes:
    - Functions here return raw-ish dictionaries built from the SDK's
      typed objects — NOT the typed SDK objects themselves. This keeps
      tools/ files decoupled from SDK internals.
    - top=N parameters map directly to Graph API's $top OData query
      parameter, which limits how many results come back.
"""

# ---------------------------------------------------------------------------
# Imports
# ---------------------------------------------------------------------------
from graph.graph_client_factory import build_graph_client
from utils.logger import get_logger

logger = get_logger(__name__)


# ---------------------------------------------------------------------------
# Helper: convert a Graph SDK Message object into a plain dict
# ---------------------------------------------------------------------------
def _message_to_dict(message) -> dict:
    """
    Convert a single Graph SDK Message object into a plain Python dict
    with the fields this project actually uses. Keeping this conversion
    in one helper avoids repeating the same field-mapping logic in every
    function below.
    """
    return {
        "id": message.id,
        "subject": message.subject,
        "from": {
            "emailAddress": {
                "name": message.from_.email_address.name if message.from_ else None,
                "address": message.from_.email_address.address if message.from_ else None,
            }
        },
        "receivedDateTime": (
            message.received_date_time.isoformat() if message.received_date_time else None
        ),
        "hasAttachments": message.has_attachments,
        "bodyPreview": message.body_preview or "",
        "body": {
            "content": message.body.content if message.body else "",
        },
    }


# ---------------------------------------------------------------------------
# Function: fetch_recent_messages
# ---------------------------------------------------------------------------
async def fetch_recent_messages(top: int = 10) -> list[dict]:
    """
    Fetch the most recent messages from the user's inbox, ordered by
    received date (newest first).

    Args:
        top (int): Maximum number of messages to fetch.

    Returns:
        list[dict]: A list of message dictionaries (see _message_to_dict).
    """
    logger.debug(f"Calling Graph API: GET /me/messages (top={top})")

    client = build_graph_client()

    # Step 1: The Graph SDK uses a request-configuration pattern for
    #         query parameters like $top and $orderby, rather than plain
    #         keyword arguments. This builds that configuration object.
    from msgraph.generated.users.item.messages.messages_request_builder import (
        MessagesRequestBuilder,
    )

    request_config = MessagesRequestBuilder.MessagesRequestBuilderGetRequestConfiguration(
        query_parameters=MessagesRequestBuilder.MessagesRequestBuilderGetQueryParameters(
            top=top,
            orderby=["receivedDateTime DESC"],
        )
    )

    # Step 2: Call GET /me/messages with that configuration.
    response = await client.me.messages.get(request_configuration=request_config)

    # Step 3: response.value holds the actual list of Message objects.
    #         Convert each one to our plain-dict shape before returning.
    messages = response.value if response and response.value else []
    return [_message_to_dict(msg) for msg in messages]


# ---------------------------------------------------------------------------
# Function: fetch_message_by_id
# ---------------------------------------------------------------------------
async def fetch_message_by_id(message_id: str) -> dict:
    """
    Fetch a single email message's full content by its Graph API ID.

    Args:
        message_id (str): The unique Graph API ID of the message.

    Returns:
        dict: The message dictionary (see _message_to_dict), including
              full body content (not just a preview).
    """
    logger.debug(f"Calling Graph API: GET /me/messages/{message_id}")

    client = build_graph_client()

    # Step 1: Call GET /me/messages/{id}. The SDK's by_message_id()
    #         method builds the correct URL path automatically.
    message = await client.me.messages.by_message_id(message_id).get()

    return _message_to_dict(message)


# ---------------------------------------------------------------------------
# Function: search_messages_by_keyword
# ---------------------------------------------------------------------------
async def search_messages_by_keyword(keyword: str, top: int = 10) -> list[dict]:
    """
    Search the user's mailbox for messages matching a keyword, using
    Graph API's built-in $search capability.

    Args:
        keyword (str): The search term.
        top (int): Maximum number of matching messages to return.

    Returns:
        list[dict]: A list of matching message dictionaries.
    """
    logger.debug(f"Calling Graph API: GET /me/messages?$search='{keyword}' (top={top})")

    client = build_graph_client()

    from msgraph.generated.users.item.messages.messages_request_builder import (
        MessagesRequestBuilder,
    )

    # Step 1: Graph API's $search parameter requires the search term to
    #         be wrapped in quotes within the query string itself.
    request_config = MessagesRequestBuilder.MessagesRequestBuilderGetRequestConfiguration(
        query_parameters=MessagesRequestBuilder.MessagesRequestBuilderGetQueryParameters(
            search=f'"{keyword}"',
            top=top,
        ),
        # Step 2: Graph API requires this header whenever $search is
        #         used, since search results aren't ordered in the
        #         normal way and the API needs to know the caller
        #         understands that ("eventual consistency" behaviour).
        headers={"ConsistencyLevel": "eventual"},
    )

    response = await client.me.messages.get(request_configuration=request_config)

    messages = response.value if response and response.value else []
    return [_message_to_dict(msg) for msg in messages]
