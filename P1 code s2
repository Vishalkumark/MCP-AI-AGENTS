## 1. `config/` Folder

This is the single place that reads `.env` and exposes clean, typed configuration to the rest of the application. No other file in the project ever calls `os.getenv()` directly.

---

### 1.1 `config/settings.py`

```python
"""
settings.py
===========
Loads environment variables from .env and exposes them as a single,
typed, organised configuration object used throughout the project.

Why this file exists:
    Without this file, every module would need to call os.getenv() or
    load_dotenv() itself, and a typo in a variable name (e.g.
    "AZURE_CLIENT_ID" vs "AZURE_CLIENTID") would fail silently somewhere
    deep in the code. By centralising this in one place, a missing or
    misspelled variable is caught immediately on startup, with a clear
    error, rather than causing a mysterious failure later.

Design notes:
    - This module loads .env ONCE, when first imported, and the resulting
      `settings` object is reused everywhere (Python caches module imports,
      so this is efficient — .env is not re-read on every function call).
    - Settings are grouped using a dataclass for readability and so that
      your editor's autocomplete can suggest valid setting names.
    - Required vs optional settings are clearly distinguished: required
      settings raise an error immediately if missing, so problems are
      caught at startup, not buried inside a tool call three layers deep.
"""

# ---------------------------------------------------------------------------
# Imports
# ---------------------------------------------------------------------------
import os
from dataclasses import dataclass, field
from dotenv import load_dotenv

# Step 1: Load the .env file into the process's environment variables.
#         This must happen before we try to read any of them below.
load_dotenv()


# ---------------------------------------------------------------------------
# Helper: required environment variable getter
# ---------------------------------------------------------------------------
def _get_required(var_name: str) -> str:
    """
    Read a required environment variable. Raises a clear error immediately
    if it's missing, rather than letting the app start in a broken state.
    """
    value = os.getenv(var_name)
    if not value:
        raise EnvironmentError(
            f"Missing required environment variable: '{var_name}'. "
            f"Please check your .env file."
        )
    return value


def _get_optional(var_name: str, default: str = "") -> str:
    """
    Read an optional environment variable, returning a default if not set.
    Used for settings that have sensible fallbacks (e.g. log level).
    """
    return os.getenv(var_name, default)


def _get_bool(var_name: str, default: bool = False) -> bool:
    """
    Read an environment variable as a boolean. .env files store everything
    as strings, so "true"/"false" need explicit conversion.
    """
    value = os.getenv(var_name, str(default)).strip().lower()
    return value in ("true", "1", "yes")


def _get_int(var_name: str, default: int) -> int:
    """
    Read an environment variable as an integer, with a fallback default.
    """
    value = os.getenv(var_name)
    if value is None or value == "":
        return default
    return int(value)


# ---------------------------------------------------------------------------
# Settings dataclass — organised by logical group
# ---------------------------------------------------------------------------
@dataclass
class Settings:
    """
    A single object holding every configuration value the application
    needs, grouped logically to match the .env file's sections.
    """

    # --- Azure / Entra ID ---
    AZURE_CLIENT_ID: str = field(default_factory=lambda: _get_required("AZURE_CLIENT_ID"))
    AZURE_CLIENT_SECRET: str = field(default_factory=lambda: _get_required("AZURE_CLIENT_SECRET"))
    AZURE_TENANT_ID: str = field(default_factory=lambda: _get_required("AZURE_TENANT_ID"))
    AZURE_AUTHORITY: str = field(default_factory=lambda: _get_required("AZURE_AUTHORITY"))

    # --- Microsoft Graph API ---
    GRAPH_API_BASE_URL: str = field(
        default_factory=lambda: _get_optional(
            "GRAPH_API_BASE_URL", "https://graph.microsoft.com/v1.0"
        )
    )
    GRAPH_API_SCOPES: str = field(
        default_factory=lambda: _get_optional(
            "GRAPH_API_SCOPES", "Mail.Read,Calendars.Read,User.Read"
        )
    )

    # --- Requesty.AI ---
    REQUESTY_API_KEY: str = field(default_factory=lambda: _get_required("REQUESTY_API_KEY"))
    REQUESTY_BASE_URL: str = field(
        default_factory=lambda: _get_optional(
            "REQUESTY_BASE_URL", "https://router.requesty.ai/v1"
        )
    )
    REQUESTY_PRIMARY_MODEL: str = field(
        default_factory=lambda: _get_optional(
            "REQUESTY_PRIMARY_MODEL", "azure/gpt-4.1-nano@swedencentral"
        )
    )
    REQUESTY_FALLBACK_MODEL: str = field(
        default_factory=lambda: _get_optional(
            "REQUESTY_FALLBACK_MODEL", "mistral/mistral-small-2603"
        )
    )

    # --- FastMCP server ---
    MCP_HOST: str = field(default_factory=lambda: _get_optional("MCP_HOST", "0.0.0.0"))
    MCP_PORT: int = field(default_factory=lambda: _get_int("MCP_PORT", 8000))
    MCP_SERVER_NAME: str = field(
        default_factory=lambda: _get_optional("MCP_SERVER_NAME", "outlook-ai-agent-mcp")
    )
    MCP_TRANSPORT: str = field(
        default_factory=lambda: _get_optional("MCP_TRANSPORT", "streamable-http")
    )

    # --- LibreChat ---
    LIBRECHAT_DOMAIN: str = field(default_factory=lambda: _get_optional("LIBRECHAT_DOMAIN"))

    # --- Attachment processing ---
    MAX_ATTACHMENT_SIZE_MB: int = field(
        default_factory=lambda: _get_int("MAX_ATTACHMENT_SIZE_MB", 25)
    )
    ATTACHMENT_TEMP_DIR: str = field(
        default_factory=lambda: _get_optional("ATTACHMENT_TEMP_DIR", "./temp_attachments")
    )
    OCR_ENABLED: bool = field(default_factory=lambda: _get_bool("OCR_ENABLED", False))
    TESSERACT_CMD_PATH: str = field(
        default_factory=lambda: _get_optional("TESSERACT_CMD_PATH", "")
    )

    # --- Logging ---
    LOG_LEVEL: str = field(default_factory=lambda: _get_optional("LOG_LEVEL", "INFO"))

    def graph_scopes_list(self) -> list[str]:
        """
        Convert the comma-separated GRAPH_API_SCOPES string into a clean
        Python list, since MSAL expects scopes as a list, not a string.
        """
        return [scope.strip() for scope in self.GRAPH_API_SCOPES.split(",") if scope.strip()]


# ---------------------------------------------------------------------------
# Module-level singleton
# ---------------------------------------------------------------------------
# This is the object every other file in the project imports:
#     from config.settings import settings
# It's created once, here, when this module is first imported.
settings = Settings()
```

