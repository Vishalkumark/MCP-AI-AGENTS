### 3.3 `graph/calendar_client.py`

```python
"""
calendar_client.py
===================
Contains Graph API functions related to reading calendar events.
Phase 1 scope is read-only — fetching the calendarView within a date
range. Creating or modifying events is deferred to Phase 2 (requires
Calendars.ReadWrite, which is not yet granted).

Why this file exists:
    Same pattern as mail_client.py: isolates all calendar-related Graph
    API calls in one place, so tools/calendar_tools.py never talks to
    the Graph SDK directly.
"""

# ---------------------------------------------------------------------------
# Imports
# ---------------------------------------------------------------------------
from datetime import datetime

from graph.graph_client_factory import build_graph_client
from utils.logger import get_logger

logger = get_logger(__name__)


# ---------------------------------------------------------------------------
# Function: fetch_calendar_events
# ---------------------------------------------------------------------------
async def fetch_calendar_events(start_dt: datetime, end_dt: datetime) -> list[dict]:
    """
    Fetch the user's calendar events within a given date/time range,
    using Graph API's calendarView endpoint (which correctly expands
    recurring meetings into individual occurrences, unlike the plain
    /events endpoint).

    Args:
        start_dt (datetime): Start of the date range to query.
        end_dt (datetime): End of the date range to query.

    Returns:
        list[dict]: A list of event dictionaries with subject, start/end
                    times, organiser, location, and online-meeting flag.
    """
    logger.debug(
        f"Calling Graph API: GET /me/calendarView "
        f"(start={start_dt.isoformat()}, end={end_dt.isoformat()})"
    )

    client = build_graph_client()

    from msgraph.generated.users.item.calendar_view.calendar_view_request_builder import (
        CalendarViewRequestBuilder,
    )

    # Step 1: calendarView requires startDateTime and endDateTime as
    #         query parameters (this is different from a request body —
    #         it's how Graph API expects the range to be specified for
    #         this specific endpoint).
    request_config = CalendarViewRequestBuilder.CalendarViewRequestBuilderGetRequestConfiguration(
        query_parameters=CalendarViewRequestBuilder.CalendarViewRequestBuilderGetQueryParameters(
            start_date_time=start_dt.isoformat(),
            end_date_time=end_dt.isoformat(),
            orderby=["start/dateTime"],
        )
    )

    response = await client.me.calendar_view.get(request_configuration=request_config)

    events = response.value if response and response.value else []

    # Step 2: Convert each SDK Event object into a plain dict, matching
    #         the shape tools/calendar_tools.py expects.
    result = []
    for event in events:
        result.append({
            "subject": event.subject,
            "start": {"dateTime": event.start.date_time if event.start else None},
            "end": {"dateTime": event.end.date_time if event.end else None},
            "organizer": {
                "emailAddress": {
                    "name": (
                        event.organizer.email_address.name
                        if event.organizer and event.organizer.email_address
                        else None
                    )
                }
            },
            "location": {
                "displayName": event.location.display_name if event.location else ""
            },
            "isOnlineMeeting": event.is_online_meeting or False,
        })

    return result
