### 3.1 `graph/graph_client_factory.py`

```python
"""
graph_client_factory.py
=========================
Builds a ready-to-use, authenticated Microsoft Graph SDK client for the
current request, and also provides a couple of simple top-level Graph
calls (like fetching the user's own profile) that don't belong in any
more specific client file.

Why this file exists:
    Every file in graph/ (mail_client.py, calendar_client.py,
    attachment_client.py) needs an authenticated Graph client to work
    with. Rather than each file building its own, they all call this
    factory function — avoiding duplicated connential-wiring logic.

Design notes:
    - A NEW client is built on every call, scoped to the current request's
      token. This is intentional and correct for a multi-user-capable
      design: we never want to accidentally reuse one user's authenticated
      client for another user's request.
"""

# ---------------------------------------------------------------------------
# Imports
# ---------------------------------------------------------------------------
from msgraph import GraphServiceClient

from auth.graph_auth import get_graph_credential
from config.settings import settings
from utils.logger import get_logger

logger = get_logger(__name__)


# ---------------------------------------------------------------------------
# Function: build_graph_client
# ---------------------------------------------------------------------------
def build_graph_client() -> GraphServiceClient:
    """
    Construct a Microsoft Graph SDK client authenticated for the current
    request's user, using their delegated OAuth token.

    Returns:
        GraphServiceClient: The official SDK client object, ready to use
                             for any Graph API call (e.g. client.me.get()).
    """
    # Step 1: Get the credential adapter wrapping this request's token.
    credential = get_graph_credential()

    # Step 2: Build the SDK client, telling it which permission scopes
    #         it's allowed to request (matches what's already been
    #         consented in the Azure App Registration).
    client = GraphServiceClient(
        credentials=credential,
        scopes=settings.graph_scopes_list(),
    )

    return client


# ---------------------------------------------------------------------------
# Function: get_user_profile
# ---------------------------------------------------------------------------
async def get_user_profile() -> dict:
    """
    Fetch the current user's basic profile from Microsoft Graph
    (GET /me). Used by tools/profile_tools.py.

    Returns:
        dict: The raw Graph API user object, converted to a plain dict
              so calling code doesn't need to know about SDK-specific
              object types.
    """
    logger.debug("Calling Graph API: GET /me")

    # Step 1: Build an authenticated client for this request.
    client = build_graph_client()

    # Step 2: Call the SDK's "me" endpoint. The Graph SDK is built so
    #         that client.me.get() maps directly to GET /me.
    user = await client.me.get()

    # Step 3: The SDK returns a typed User object, not a plain dict.
    #         We convert the fields we care about into a plain dict here
    #         so the rest of the app never needs to import SDK model types.
    return {
        "displayName": user.display_name,
        "mail": user.mail,
        "userPrincipalName": user.user_principal_name,
        "jobTitle": user.job_title,
    }
```

