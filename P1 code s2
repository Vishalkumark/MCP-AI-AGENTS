### 2.2 `auth/graph_auth.py`

```python
"""
graph_auth.py
=============
Validates and prepares the OAuth access token for use with Microsoft
Graph API calls.

Why this file exists:
    token_cache.py knows HOW to find the raw token string from the
    incoming request. This file knows what to DO with that token once
    found — confirming it's well-formed enough to use, and packaging it
    in the shape the Microsoft Graph SDK expects.

Design notes:
    - This project uses DELEGATED auth, meaning the token already
      represents a specific logged-in user (you) — it was obtained by
      LibreChat during the OAuth login flow, not generated by this
      server. This file never requests new tokens or stores credentials;
      it only validates and forwards what it's given.
    - The msgraph-sdk-python library expects an "credential" object
      implementing a specific interface, not just a raw string. This
      file provides a minimal adapter class to bridge that gap.
"""

# ---------------------------------------------------------------------------
# Imports
# ---------------------------------------------------------------------------
from azure.core.credentials import AccessToken
import time

from auth.token_cache import get_current_user_token
from utils.logger import get_logger

logger = get_logger(__name__)


# ---------------------------------------------------------------------------
# Class: DelegatedTokenCredential
# ---------------------------------------------------------------------------
class DelegatedTokenCredential:
    """
    A minimal adapter that wraps a raw OAuth access token string so it
    satisfies the credential interface the Microsoft Graph SDK expects
    (specifically, Azure's TokenCredential protocol, which requires a
    get_token() method).

    Why this class is needed:
        The official msgraph-sdk-python library is designed to work with
        Azure's credential objects (like InteractiveBrowserCredential or
        ClientSecretCredential), which normally fetch their own tokens.
        In our case, LibreChat has ALREADY obtained the token via the
        OAuth flow — we just need to hand it to the SDK in the expected
        shape, without the SDK trying to fetch a new one itself.
    """

    def __init__(self, raw_token: str):
        # Step 1: Store the raw token string passed in from token_cache.py.
        self._raw_token = raw_token

    def get_token(self, *scopes, **kwargs) -> AccessToken:
        """
        Required method for Azure's TokenCredential interface. The Graph
        SDK calls this internally whenever it needs to attach a token to
        an outgoing request.

        Returns:
            AccessToken: An Azure SDK object pairing the token string
                         with an expiry timestamp.
        """
        # Step 2: We don't have the actual expiry time of this token
        #         (LibreChat manages refresh on its side), so we report
        #         a short artificial expiry. This just tells the Graph
        #         SDK "treat this as valid for this one call" — it does
        #         not affect the token's real expiry on Microsoft's side.
        artificial_expiry = int(time.time()) + 300  # 5 minutes from now

        return AccessToken(self._raw_token, artificial_expiry)


# ---------------------------------------------------------------------------
# Function: get_graph_credential
# ---------------------------------------------------------------------------
def get_graph_credential() -> DelegatedTokenCredential:
    """
    Build a Graph-SDK-compatible credential object for the current
    request, using the logged-in user's OAuth token.

    This is the main entry point other files (graph_client_factory.py)
    call to get something they can hand directly to the Graph SDK client
    constructor.

    Returns:
        DelegatedTokenCredential: Ready to pass into the Graph SDK client.
    """
    # Step 1: Get the raw token string for whoever is making this request.
    #         This will raise AuthorizationError if missing/malformed —
    #         we deliberately let that propagate up, since a tool call
    #         genuinely cannot proceed without a valid token.
    raw_token = get_current_user_token()

    logger.debug("Built delegated Graph credential for current request")

    # Step 2: Wrap it in our adapter class and return.
    return DelegatedTokenCredential(raw_token)
```

